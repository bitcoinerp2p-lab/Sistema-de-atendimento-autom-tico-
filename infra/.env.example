# Copie este arquivo para .env e preencha antes de subir o docker compose.

# --- Geral ---
ENVIRONMENT=development

# --- Postgres ---
POSTGRES_USER=orion
POSTGRES_PASSWORD=orion
POSTGRES_DB=orion
DATABASE_URL=postgresql+asyncpg://orion:orion@postgres:5432/orion

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333

# --- Agent runtime (stand-in para o OpenClaw na Fase 1) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Regra constitucional: nunca ative sem um Scale Tracking real integrado ---
SCALE_TRACKING_ENABLED=false

# --- Segurança (troque em produção) ---
JWT_SECRET=change-me-in-production
HMAC_SHARED_SECRET=change-me-in-production

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_KEY=change-me
